{
  "$schema": "./schemas/routing-schema.json",
  "version": "1.0",

  "tasks": {
    "reasoning": {
      "description": "Complex reasoning, analysis, strategy",
      "advisor": {
        "provider": "github-copilot",
        "model": "claude-opus-4.6"
      },
      "worker": {
        "provider": "github-copilot",
        "model": "claude-sonnet-4.5"
      },
      "maxIterations": 3
    },

    "codeGeneration": {
      "description": "Code writing, refactoring",
      "advisor": {
        "provider": "github-copilot",
        "model": "claude-sonnet-4.5"
      },
      "worker": {
        "provider": "github-copilot",
        "model": "claude-haiku-4.5"
      },
      "maxIterations": 2
    },

    "webSearch": {
      "description": "Web search and information gathering",
      "advisor": {
        "provider": "zai",
        "model": "glm-4.5-flash"
      },
      "worker": {
        "provider": "zai",
        "model": "glm-4.5"
      },
      "maxIterations": 1
    },

    "imageProcessing": {
      "description": "Image analysis, modification",
      "advisor": {
        "provider": "github-copilot",
        "model": "claude-opus-4.6"
      },
      "worker": {
        "provider": "github-copilot",
        "model": "claude-sonnet-4.5"
      },
      "maxIterations": 2
    },

    "review": {
      "description": "Code review, debugging",
      "advisor": {
        "provider": "github-copilot",
        "model": "claude-opus-4.6"
      },
      "worker": {
        "provider": "github-copilot",
        "model": "claude-opus-4.6"
      },
      "maxIterations": 3
    },

    "simple": {
      "description": "Simple tasks, summaries, translations",
      "advisor": {
        "provider": "zai",
        "model": "glm-4.5-flash"
      },
      "worker": {
        "provider": "zai",
        "model": "glm-4.5-flash"
      },
      "maxIterations": 1
    },

    "default": {
      "description": "Default task type",
      "advisor": {
        "provider": "github-copilot",
        "model": "claude-sonnet-4.5"
      },
      "worker": {
        "provider": "github-copilot",
        "model": "claude-sonnet-4.5"
      },
      "maxIterations": 2
    }
  }
}
