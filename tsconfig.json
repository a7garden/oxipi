{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@oxipi/ai": ["./packages/ai/src/index.ts"],
			"@oxipi/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@oxipi/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@oxipi/ai/dist/*": ["./packages/ai/src/*"],
			"@oxipi/agent-core": ["./packages/agent/src/index.ts"],
			"@oxipi/agent-core/*": ["./packages/agent/src/*"],
			"@oxipi/coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@oxipi/coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@oxipi/coding-agent/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@oxipi/mom": ["./packages/mom/src/index.ts"],
			"@oxipi/mom/*": ["./packages/mom/src/*"],
			"@oxipi/pods": ["./packages/pods/src/index.ts"],
			"@oxipi/pods/*": ["./packages/pods/src/*"],
			"@oxipi/tui": ["./packages/tui/src/index.ts"],
			"@oxipi/tui/*": ["./packages/tui/src/*"],
			"@oxipi/web-ui": ["./packages/web-ui/src/index.ts"],
			"@oxipi/web-ui/*": ["./packages/web-ui/src/*"],
			"@oxipi/agent-old": ["./packages/agent-old/src/index.ts"],
			"@oxipi/agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
